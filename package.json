{
  "name": "rael",
  "version": "2.0.0",
  "description": "AI-powered Discord bot built for natural conversation, multi-model flexibility, and useful utilities like vision, web search, live stock data, and usage tracking",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "discord",
    "discord-bot",
    "ai",
    "groq",
    "openrouter",
    "typescript",
    "bun"
  ],
  "author": "Caleb Ephrem",
  "license": "GPL-3.0-only",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22"
  },
  "dependencies": {
    "@ai-sdk/groq": "4.0.2",
    "@napi-rs/canvas": "^1.0.1",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "ai": "7.0.8",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "exa-js": "^2.15.0",
    "latex-to-unicode": "^0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
